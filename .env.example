# Адреса розгорнутого Qorax API Worker.
# Локально (worker запущений через `npm run dev` у /worker): http://localhost:8787
# На продакшені — задається в Cloudflare Pages → Settings → Environment variables
# після деплою Worker (npm run deploy у /worker виведе реальну адресу).
NEXT_PUBLIC_API_URL=http://localhost:8787
